# Demo mode is on by default.
DEMO_MODE=true

# Simnet RPC is disabled unless explicitly enabled for isolated local proof.
DCR_SIMNET_ENABLED=false

# Isolated simnet dcrd RPC. Do not use mainnet endpoints here.
DCRD_SIMNET_RPC_URL=
DCRD_SIMNET_RPC_USER=
DCRD_SIMNET_RPC_PASSWORD=
DCRD_SIMNET_RPC_CERT_PATH=

# Separate borrower dcrwallet RPC for simnet proof.
DCRWALLET_SIMNET_BORROWER_RPC_URL=
DCRWALLET_SIMNET_BORROWER_RPC_USER=
DCRWALLET_SIMNET_BORROWER_RPC_PASSWORD=
DCRWALLET_SIMNET_BORROWER_RPC_CERT_PATH=
DCRWALLET_SIMNET_BORROWER_ACCOUNT=

# Separate lender dcrwallet RPC for simnet proof.
DCRWALLET_SIMNET_LENDER_RPC_URL=
DCRWALLET_SIMNET_LENDER_RPC_USER=
DCRWALLET_SIMNET_LENDER_RPC_PASSWORD=
DCRWALLET_SIMNET_LENDER_RPC_CERT_PATH=
DCRWALLET_SIMNET_LENDER_ACCOUNT=

# Separate arbiter dcrwallet RPC for simnet proof.
DCRWALLET_SIMNET_ARBITER_RPC_URL=
DCRWALLET_SIMNET_ARBITER_RPC_USER=
DCRWALLET_SIMNET_ARBITER_RPC_PASSWORD=
DCRWALLET_SIMNET_ARBITER_RPC_CERT_PATH=
DCRWALLET_SIMNET_ARBITER_ACCOUNT=

# Optional future integrations.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
BASE_RPC_URL=
TREASURY_EVM_PRIVATE_KEY=
